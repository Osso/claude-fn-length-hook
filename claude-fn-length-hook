#!/bin/bash
# PostToolUse hook: Enforce max 50 lines per Rust function body
# Counts non-blank, non-comment, non-brace-only lines inside fn bodies
set -euo pipefail

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')

# Only check existing Rust files
[[ "$FILE_PATH" == *.rs && -f "$FILE_PATH" ]] || exit 0

VIOLATIONS=$(awk '
BEGIN { limit = 50 }
{
    line = $0

    # --- Strip comments and strings for brace/keyword detection ---

    if (in_block_comment) {
        if (index(line, "*/")) {
            in_block_comment = 0
            sub(/.*\*\//, "", line)
        } else {
            next
        }
    }
    gsub(/\/\*.*\*\//, "", line)
    if (index(line, "/*")) {
        in_block_comment = 1
        sub(/\/\*.*/, "", line)
    }
    gsub(/"([^"\\]|\\.)*"/, "", line)
    sub(/\/\/.*/, "", line)

    # --- Detect function definition (only when not inside another fn) ---

    if (!in_fn && line ~ /(^|[^a-zA-Z0-9_])fn[[:space:]]+[a-zA-Z_]/) {
        name = line
        sub(/.*fn[[:space:]]+/, "", name)
        sub(/[^a-zA-Z0-9_].*/, "", name)

        fn_name = name
        fn_start = NR
        in_fn = 1
        depth = 0
        body_lines = 0
        body_started = 0
    }

    # --- Track brace depth inside function ---

    if (in_fn) {
        tmp = line
        while (match(tmp, /[{}]/)) {
            ch = substr(tmp, RSTART, 1)
            tmp = substr(tmp, RSTART + 1)

            if (ch == "{") {
                depth++
                if (depth == 1) body_started = 1
            } else {
                depth--
                if (depth == 0 && body_started) {
                    if (body_lines > limit)
                        printf "  - %s (line %d): %d body lines\n", fn_name, fn_start, body_lines
                    in_fn = 0
                    body_started = 0
                    break
                }
            }
        }

        # --- Count qualifying body lines ---

        if (body_started && depth >= 1) {
            s = $0
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)

            if (s == "") next
            if (s ~ /^\/\//) next
            if (s ~ /^\/?\*/) next
            if (s == "{" || s == "}" || s == "};") next

            body_lines++
        }
    }
}
' "$FILE_PATH")

if [[ -n "$VIOLATIONS" ]]; then
    REASON=$(printf "Function body exceeds 50-line limit in %s:\n%s\nExtract logic into well-named helper functions." \
        "$(basename "$FILE_PATH")" "$VIOLATIONS")
    jq -n --arg reason "$REASON" '{"decision":"block","reason":$reason}'
fi
exit 0
